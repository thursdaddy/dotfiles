[global]
    font = Hack 9
    frame_width = 1
    frame_color = "#00000"
    
    markup = yes
    
    # The format of the message.  Possible variables are:
    #   %a  appname
    #   %s  summary
    #   %b  body
    #   %i  iconname (including its path)
    #   %I  iconname (without its path)
    #   %p  progress value if set ([  0%] to [100%]) or nothing
    # Markup is allowed
    format = "%s\n\n%b"
    
    sort = yes
    indicate_hidden = yes
    alignment = left
    bounce_freq = 0
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    geometry = "0x0-20-65"
    shrink = no
    transparency = 20
    idle_threshold = 120
    monitor = 0
    follow = mouse
    sticky_history = yes
    history_length = 20
    show_indicators = yes
    line_height = 0
    separator_height = 5
    padding = 20
    horizontal_padding = 20
    separator_color = frame
    startup_notification = false
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/vivaldi-stable
    icon_position = off
    icon_path = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/

[shortcuts]
    close = ctrl+space
    close_all = ctrl+shift+space

[urgency_low]
    background = "#000000"
    foreground = "#c0c5ce"
    timeout = 30

[urgency_normal]
    background = "#000000"
    foreground = "#c0c5ce"
    timeout = 30

[urgency_critical]
    background = "#000000"
    foreground = "#c0c5ce"
    timeout = 30
