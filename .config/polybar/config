### COLORS ###

[colors]
background = ${xrdb:color6}
background-alt = ${xrdb:color3} 
background-unf = ${xrdb:color6}

foreground = ${xrdb:color15} 
foreground-alt = ${xrdb:color15} 
foreground-unf = ${xrdb:color15}
foreground-foc = ${xrdb:color2} 
foreground-alrt = #db0707
foreground-warn = #eecc04

### MAIN BAR ###

[bar/main]
monitor = ${env:MONITOR:}
width = 100%
height = 25
offset-x = 0
offset-y = 0
radius = 10.0
fixed-center = true
bottom = true 

font-0 = "Hack:fontformat=truetype:size=10;1"
font-1 = "Font Awesome 5 Free:style=Regularpixelsize=11;1"
font-2 = "Font Awesome 5 Free:style=Solid:pixelsize=11;1"
font-3 = "Font Awesome 5 Brands:pixelsize=11;1"

modules-center = i3
modules-left = date weather 
modules-right = battery backlight pvolume memory cpu updates  

# sets bar to transparent 
background = #00000000
foreground = ${colors.foreground}

border-bottom-size = 0
border-top-size = 3
border-left-size = 5
border-right-size = 5
border-color = #00000000

padding-left = 1
padding-right = 1

module-margin-left = 1
module-margin-right = 1

tray-position = right
tray-padding = 5
tray-transparent = true 
tray-maxsize = 20
tray-detached = false
wm-restack = i3

### SIDE BAR ###

[bar/side]
monitor = ${env:MONITOR:}
width = 100%
height = 30
offset-x = 0%
offset-y = 0%
radius = 0.0
fixed-center = true
bottom = true 

modules-left = date weather 
modules-center = i3 
modules-right = battery backlight pvolume memory cpu 

# sets bar to transparent 
background = #00000000
foreground = ${colors.foreground}

padding-left = 1
padding-right = 1

module-margin-right = 1
module-margin-left = 1

font-0 = "Hack:fontformat=truetype:size=9;1"
font-1 = "Font Awesome 5 Free:style=Regularpixelsize=11;1"
font-2 = "Font Awesome 5 Free:style=Solid:pixelsize=11;1"
font-3 = "Font Awesome 5 Brands:pixelsize=11;1"

tray-position = right
tray-padding = 10
tray-transparent = true
tray-maxsize = 18
tray-detached = false
wm-restack = i3

### MODULES ###

[module/i3]
type = internal/i3
index-sort = true
strip-wsnumbers = false
pin-workspaces = true

ws-icon-1 = 1;’äĀ
ws-icon-0 = 2;’āĆ
ws-icon-2 = 3;’ē©
ws-icon-3 = 4;’Ćü
ws-icon-4 = 5;’Ŗü
ws-icon-5 = 6;’äø
ws-icon-6 = 7;7
ws-icon-7 = 8;8
ws-icon-8 = 9;’ć║
ws-icon-9 = 0;’ćĖ

format = <label-state> <label-mode>

label-unfocused-foreground = ${colors.foreground-unf} 
label-mode = %mode%
label-mode-padding = 1
label-mode-background = ${colors.background}

label-focused = %icon%
label-focused-foreground = ${colors.foreground-foc} 
label-focused-padding = 1

label-unfocused = %icon%
label-unfocused-padding = 1 

label-visible = %icon%
label-visible-underline = #555555
label-visible-padding = 1

label-urgent = %icon%
label-urgent-foreground = ${colors.foreground-alrt}
label-urgent-padding = 1

[module/weather_icons]
type = custom/script
exec = ~/.config/scripts/weather_icons.py
interval = 600

[module/backlight]
type = internal/xbacklight
card = intel_backlight
format-prefix-foreground = ${colors.foreground-alt}
format = <label>
label = %percentage%%
output = eDP1
enable-scroll = true
format-prefix = "’éŻ "
label-active = %token%

[module/date]
type = internal/date
interval = 1
time = "%l:%M:%S %p    %a, %b %d"

format-prefix-foreground = ${colors.foreground-foc}
label-active = %token%
format-padding = 1
label = %time%

[module/title]
type = internal/xwindow
format-background = ${colors.background}
format-foreground = ${colors.foreground}

[module/updates]
type = custom/script
exec = ~/.config/scripts/updates.sh
interval = 60
format = <label>
label = "%output:0:30%"
label-active = %token%
format-prefix-foreground = ${colors.foreground-alt}

[module/pvolume]
type = custom/script
interval = 1
label = %output%
exec = ~/.config/scripts/volume.sh
click-right = exec pavucontrol
click-left = ~/.config/scripts/volume.sh --togmute
scroll-up = ~/.config/scripts/volume.sh --up
scroll-down = ~/.config/scripts/volume.sh --down
format = <label>
format-prefix-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 100
format-charging = <animation-charging> <label-charging>
format-discharging = <ramp-capacity> <label-discharging>
label-full =’ēĆ %percentage%

ramp-capacity-0 = ’ēä
ramp-capacity-0-foreground = ${colors.foreground-alrt}
ramp-capacity-1 = ’ēā
ramp-capacity-1-foreground = ${colors.foreground-warn}
ramp-capacity-2 = ’ēé
ramp-capacity-3 = ’ēü
ramp-capacity-4 = ’ēĆ
ramp-capacity-foreground = ${colors.foreground-alt}

animation-charging-0 = ’ēä
animation-charging-1 = ’ēā
animation-charging-2 = ’ēé
animation-charging-3 = ’ēü
animation-charging-4 = ’ēĆ
animation-charging-foreground = ${colors.foreground-foc}
animation-charging-framerate = 750

[module/weather]
type = custom/script
interval = 3600
format = <label>
format-prefix = " ’āé   "
format-prefix-foreground = ${colors.foreground-alt}
exec = ~/.config/scripts/weather.py

[module/cpu]
type = internal/cpu
interval = 1
format-prefix = "’ŗø " 
format-prefix-foreground = ${colors.foreground-alt}
label = %percentage%%
label-foreground = ${colors.foreground}

[module/memory]
type = internal/memory
interval = 2
format-prefix = "’ł│ "
format-prefix-foreground = ${colors.foreground-alt}
label = %percentage_used%%
label-foreground = ${colors.foreground}

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-back2ground = screen
;compositing-foreground = source
;compositing-border = over

[global/wm]
margin-top = 0
margin-bottom = 0

