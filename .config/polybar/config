[colors]
background = #000f0f0f
background-alt = #000f0f0f 
background-unf = #8b8c90
foreground-unf = #8b8c90
background-mod0 = #b48ead
background-mod1 = #96b5b4
background-mod2 = #ebcb8b
background-alrt = #e36969
foreground-foc = #fffffff

foreground = #c0c5ce 
foreground-alrt = #c0c5ce
foreground-alt = #c0c5ce
primary = #c0c5ce
secondary = #c0c5ce

[bar/main]
monitor = ${env:MONITOR:}
width = 100%
height = 25
offset-x = 0
offset-y = 0
radius = 0.0
fixed-center = true
bottom = true 

font-0 = "Hack:fontformat=truetype:size=9;1"
font-1 = "Font Awesome 5 Free:style=Regularpixelsize=9;1"
font-2 = "Font Awesome 5 Free:style=Solid:pixelsize=9;1"
font-3 = "Font Awesome 5 Brands:pixelsize=9;1"
font-4 = "Noto Sans Symbols2:style=Regular:pixelsize=12;4"
font-5 = "Hack:fontformat=truetype:size=7;1"

modules-left = cpu memory updates 
modules-center = i3
modules-right = battery backlight pvolume date

background = ${colors.background}
foreground = ${colors.foreground}

border-bottom-size = 0
border-top-size = 0
border-left-size = 5
border-right-size = 5
border-color = #00000000

padding-left = 1

module-margin-left = 1
module-margin-right = 1

tray-position = right 
tray-padding = 5
tray-transparent = true
tray-maxsize = 18
tray-detached = false
wm-restack = i3

[bar/side]
monitor = ${env:MONITOR:}
width = 100%
height = 30
offset-x = 0%
offset-y = 0%
radius = 0.0
fixed-center = true
bottom = true

modules-left = date 
modules-center = i3 
modules-right = backlight pvolume 

background = ${colors.background}
foreground = ${colors.foreground}

padding-left = 0
padding-right = 0

module-margin-left = 1
module-margin-right = 1

font-0 = "Hack:fontformat=truetype:size=9;1"
font-1 = "Font Awesome 5 Free:style=Regularpixelsize=9;1"
font-2 = "Font Awesome 5 Free:style=Solid:pixelsize=9;1"
font-3 = "Font Awesome 5 Brands:pixelsize=9;1"
font-4 = "Noto Sans Symbols2:style=Regular:pixelsize=12;4"
font-5 = "Hack:fontformat=truetype:size=7;1"

tray-position = right
tray-padding = 5
tray-transparent = true
tray-maxsize = 18
tray-detached = false
wm-restack = i3

[module/i3]
type = internal/i3
index-sort = true
strip-wsnumbers = false
pin-workspaces = true

ws-icon-1 = 1;’äĀ
ws-icon-0 = 2;’āĆ
ws-icon-2 = 3;’ē©
ws-icon-3 = 4;’Ćü
ws-icon-4 = 5;’Ŗü
ws-icon-5 = 6;’äø
ws-icon-6 = 7;7
ws-icon-7 = 8;8
ws-icon-8 = 9;’ć║
ws-icon-9 = 0;’ćĖ

format = <label-state> <label-mode>

label-unfocused-background = ${colors.background}
label-unfocused-foreground = ${colors.foreground-unf} 
label-mode = %mode%
label-mode-padding = 1
label-mode-background = ${colors.background}

label-focused = %icon%
label-focused-foreground = ${colors.foreground-foc} 
label-focused-background = ${colors.background}
label-focused-padding = 1

label-unfocused = %icon%
label-unfocused-padding = 1 

label-visible = %icon%
label-visible-underline = #555555
label-visible-padding = 1

label-urgent = %icon%
label-urgent-foreground = ${colors.foreground-alrt}
label-urgent-background = ${colors.background}
label-urgent-padding = 1

[module/weather_icons]
type = custom/script
exec = ~/.config/scripts/weather_icons.py
interval = 600

[module/backlight]
type = internal/xbacklight
card = intel_backlight
format = <label>
label = %percentage%%
output = eDP1
enable-scroll = true
format-prefix = "’éŻ "

[module/date]
type = internal/date
interval = 1
time = "%I:%M:%S"
format-prefix-foreground = ${colors.foreground-alt}
format-padding = 3
label = %time%

[module/title]
type = internal/xwindow
format-background = ${colors.background}
format-foreground = ${colors.foreground}

[module/updates]
type = custom/script
exec = ~/.config/scripts/updates.sh
interval = 60
format = <label>
label = "%output:0:30%"

[module/pvolume]
type = custom/script
interval = 1
label = %output%
exec = ~/.config/scripts/volume.sh
click-right = exec pavucontrol
click-left = ~/.config/scripts/volume.sh --togmute
scroll-up = ~/.config/scripts/volume.sh --up
scroll-down = ~/.config/scripts/volume.sh --down

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98
format-charging = <animation-charging> <label-charging>
format-discharging = <ramp-capacity> <label-discharging>
label-full =’ēĆ %percentage%

ramp-capacity-0 = ’ēä
#ramp-capacity-0-foreground = ${colors.alert}
ramp-capacity-1 = ’ēā
#ramp-capacity-1-foreground = ${colors.warning}
ramp-capacity-2 = ’ēé
ramp-capacity-3 = ’ēü
ramp-capacity-4 = ’ēĆ
#ramp-capacity-foreground = ${colors.foreground-alt}

animation-charging-0 = ’ēä
animation-charging-1 = ’ēā
animation-charging-2 = ’ēé
animation-charging-3 = ’ēü
animation-charging-4 = ’ēĆ
#animation-charging-foreground = ${colors.foreground-alt}
animation-charging-framerate = 750

[module/weather]
type = custom/script
interval = 3600
format = <label>
format-prefix = "’āé "
format-prefix-foreground = ${colors.foreground-alt}
exec = ~/.config/scripts/weather.py

[module/cpu]
type = internal/cpu
interval = 1
format-prefix = "’ŗø " 
format-prefix-foreground = ${colors.foreground}
label = %percentage%%
label-foreground = ${colors.foreground}

[module/memory]
type = internal/memory
interval = 2
format-prefix = "’ł│ "
format-prefix-foreground = ${colors.foreground}
label = %percentage_used%%
label-foreground = ${colors.foreground}

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-back2ground = screen
;compositing-foreground = source
;compositing-border = over

[global/wm]
margin-top = 0
margin-bottom = 0

